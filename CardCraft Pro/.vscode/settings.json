{
  "css.validate": true,
  "scss.validate": true,
  "less.validate": true,
  "tailwindCSS.includeLanguages": {
    "css": "css",
    "scss": "css",
    "less": "css"
  },
  "tailwindCSS.experimental.classRegex": [
    ["@apply\\s+([^;]+)", "$1"],
    ["@screen\\s+([^\\s]+)\\s+{([^}]+)", "$2"]
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "tailwindCSS.validate": true
}
